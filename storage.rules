rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Ảnh hotspot: đọc công khai, chỉ admin đã đăng nhập mới upload
    match /hotspot_images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    // Các file samples hiện có: cho phép đọc công khai
    match /samples/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
